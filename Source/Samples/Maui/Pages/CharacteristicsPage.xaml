<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:MauiSample.Models"
             xmlns:pageModels="clr-namespace:MauiSample.PageModels"
             x:DataType="pageModels:CharacteristicsPageModel"
             x:Class="MauiSample.Pages.CharacteristicsPage"
             Title="Characteristics">

    <Grid Padding="10" Margin="5,2">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- CollectionView -->
            <RowDefinition Height="Auto" />
            <!-- ActivityIndicator -->
            <RowDefinition Height="*" />
            <!-- Error Label -->
        </Grid.RowDefinitions>

        <ActivityIndicator Grid.Row="0"
                           IsVisible="{Binding IsBusy}"
                           IsRunning="{Binding IsBusy}"/>
        
        <Label Grid.Row="1"
               Text="{Binding Error}"
               FontSize="Title"
               TextColor="Brown"/>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Characteristics}"
                        SelectionMode="Single"
                        SelectedItem="{Binding Item, Mode=TwoWay}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:MyCharacteristic">
                    <VerticalStackLayout>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup Name="CommonStates">
                                <VisualState Name="Normal"></VisualState>
                                <VisualState Name="Selected">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="AliceBlue"></Setter>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="30"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <VerticalStackLayout Grid.Column="0"
                                                     Margin="8,8">
                                    <Label Text="{Binding Name}"
                                           FontSize="16"
                                           FontAttributes="Bold"/>
                                    <Label Text="{Binding Id}"
                                           FontSize="14"
                                           TextColor="DarkGray"/>
                                    <Label Text="{Binding PropertiesString}"
                                           FontSize="14"/>
                                </VerticalStackLayout>
                                <HorizontalStackLayout Grid.Column="1"
                                                       Margin="0,0,8,0"
                                                       HorizontalOptions="End">
                                    <CheckBox IsVisible="{Binding CanUpdate}"
                                              IsChecked="{Binding IsNotifying}"
                                              Margin="0,0,-4,0"/>
                                    <Button IsVisible="{Binding CanUpdate}"
                                            HorizontalOptions="End"
                                            VerticalOptions="Center"
                                            Margin="0,0,2,0"
                                            Text="N"
                                            BackgroundColor="DeepSkyBlue"
                                            FontSize="30"
                                            FontAttributes="Bold"
                                            CornerRadius="50"
                                            HeightRequest="60"
                                            WidthRequest="60"
                                            Command="{Binding ToggleNotifyingCommand,
                                                Source={RelativeSource AncestorType={x:Type pageModels:CharacteristicsPageModel}},
                                                x:DataType=pageModels:CharacteristicsPageModel}" CommandParameter="{Binding .}">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsNotifying}" Value="True">
                                                <Setter Property="BackgroundColor" Value="DeepSkyBlue"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsNotifying}" Value="False">
                                                <Setter Property="BackgroundColor" Value="LightSkyBlue"/>
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                    <Button IsVisible="{Binding CanRead}"
                                            HorizontalOptions="End"
                                            VerticalOptions="Center"
                                            Margin="2,0,2,0"
                                            Text="R"
                                            BackgroundColor="MediumTurquoise"
                                            FontSize="30"
                                            FontAttributes="Bold"
                                            CornerRadius="50"
                                            HeightRequest="60"
                                            WidthRequest="60"
                                            Command="{Binding ReadCommand,
                                                Source={RelativeSource AncestorType={x:Type pageModels:CharacteristicsPageModel}},
                                                x:DataType=pageModels:CharacteristicsPageModel}" CommandParameter="{Binding .}"/>
                                    <Button IsVisible="{Binding CanWrite}"
                                            HorizontalOptions="End"
                                            VerticalOptions="Center"
                                            Margin="2,0,2,0"
                                            Text="W"
                                            BackgroundColor="SandyBrown"
                                            FontSize="30"
                                            FontAttributes="Bold"
                                            CornerRadius="50"
                                            HeightRequest="60"
                                            WidthRequest="60"
                                            Command="{Binding WriteCommand,
                                                Source={RelativeSource AncestorType={x:Type pageModels:CharacteristicsPageModel}},
                                                x:DataType=pageModels:CharacteristicsPageModel}" CommandParameter="{Binding .}"/>
                                </HorizontalStackLayout>
                            </Grid>

                            <HorizontalStackLayout Grid.Row="1"
                                                   IsVisible="{Binding CanRead}">
                                <Label Padding="8,4"
                                       Text="{Binding ReadValue}"/>
                            </HorizontalStackLayout>
                            
                            <HorizontalStackLayout Grid.Row="1"
                                                   IsVisible="{Binding CanUpdate}">
                                <Label Padding="8,4"
                                       Text="{Binding NotifyValue}"/>
                            </HorizontalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>