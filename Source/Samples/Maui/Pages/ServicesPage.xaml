<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:MauiSample.PageModels"
             x:DataType="pageModels:ServicesPageModel"
             x:Class="MauiSample.Pages.ServicesPage"
             Title="Services">

    <CollectionView ItemsSource="{Binding Services}"
                    SelectionMode="None">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Grid Padding="10"
                      BackgroundColor="LightGray"
                      Margin="5,2">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ExploreServiceCommand}" />
                    </Grid.GestureRecognizers>

                    <VerticalStackLayout>
                        <Label Text="{Binding Name}"
                               FontSize="16"
                               FontAttributes="Bold"/>
                        <Label Text="{Binding Id}"
                               FontSize="14"
                               TextColor="DarkGray"/>
                    </VerticalStackLayout>
                </Grid>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>